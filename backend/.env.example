JWT_SECRET=replace-with-a-secure-secret
JWT_EXPIRE=7d
PORT=3000
NODE_ENV=development

# Preferred: a single connection string
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/hostel_management

# Optional discrete PostgreSQL settings when DATABASE_URL is not used
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=hostel_management
PGSSL=false

FILE_UPLOAD_DIR=uploads
